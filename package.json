{
  "name": "@clerk/mcp-tools",
  "version": "0.5.0",
  "description": "Tools for writing MCP clients and servers without pain",
  "keywords": [
    "auth",
    "clerk",
    "context",
    "mcp",
    "model",
    "protocol"
  ],
  "homepage": "https://github.com/clerk/mcp-tools#readme",
  "bugs": {
    "url": "https://github.com/clerk/mcp-tools/issues"
  },
  "license": "MIT",
  "author": "Jeff Escalante",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clerk/mcp-tools.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/",
  "exports": {
    "./client": {
      "import": "./dist/client.mjs",
      "types": "./dist/client.d.mts"
    },
    "./server": {
      "import": "./dist/server.mjs",
      "types": "./dist/server.d.mts"
    },
    "./next": {
      "import": "./dist/next/index.mjs",
      "types": "./dist/next/index.d.mts"
    },
    "./express": {
      "import": "./dist/express/index.mjs",
      "types": "./dist/express/index.d.mts"
    },
    "./stores": "./dist/stores",
    "./stores/fs": {
      "import": "./dist/stores/fs.mjs",
      "types": "./dist/stores/fs.d.mts"
    },
    "./stores/redis": {
      "import": "./dist/stores/redis.mjs",
      "types": "./dist/stores/redis.d.mts"
    },
    "./stores/postgres": {
      "import": "./dist/stores/postgres.mjs",
      "types": "./dist/stores/postgres.d.mts"
    },
    "./stores/sqlite": {
      "import": "./dist/stores/sqlite.mjs",
      "types": "./dist/stores/sqlite.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "watch": "tsdown --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@clerk/backend": "^3.2.13",
    "@clerk/express": "^2.1.5",
    "@clerk/nextjs": "^7.2.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.1.0",
    "@types/pg": "^8.15.4",
    "better-sqlite3": "^11.10.0",
    "next": "^15.5.15",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "pg": "^8.16.3",
    "redis": "^5.5.6",
    "tsdown": "^0.21.9",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@clerk/express": "^2.1.5",
    "@clerk/nextjs": "^7.2.3",
    "better-sqlite3": "^8.7.0",
    "express": "^5.0.0",
    "next": "^15.2.8 || ^15.3.8 || ^15.4.10 || ^15.5.9 || ^15.6.0-0 || ^16.0.10 || ^16.1.0-0",
    "pg": "^8.11.0",
    "redis": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@clerk/express": {
      "optional": true
    },
    "@clerk/nextjs": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}
